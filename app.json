{
  "expo": {
    "name": "chronobite",
    "slug": "chronobite",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "chronobite",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow Chronobite to transcribe what you say for hands-free meal logging.",
        "NSMicrophoneUsageDescription": "Allow Chronobite to listen so you can log meals hands-free.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.redlog.chronobite",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.redlog.chronobite"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "name": "CaloriePal",
      "shortName": "CaloriePal",
      "description": "AI-powered calorie and macro tracking. Log meals by describing what you ate.",
      "themeColor": "#6366F1",
      "backgroundColor": "#FAFBFF"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Chronobite to listen so you can log meals hands-free.",
          "speechRecognitionPermission": "Allow Chronobite to transcribe what you say for hands-free meal logging."
        }
      ],
      "@react-native-firebase/app"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "868c265b-3265-466d-a9d7-31170a1faae8"
      }
    },
    "owner": "kbhargava"
  }
}
